  },
  "files": [
    "dist"
  ],
  "keywords": [
    "opencode",
    "claude-office",
    "visualizer",
    "plugin",
    "ai",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "1.17.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
