{
  "name": "opencode-claude-office",
  "version": "0.22.0",
  "description": "OpenCode plugin that sends lifecycle events to Claude Office Visualizer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
