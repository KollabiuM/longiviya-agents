{
  "name": "opencode-claude-office",
  "version": "0.23.0",
  "description": "OpenCode plugin that sends lifecycle events to Claude Office Visualizer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "opencode",
    "claude-office",
    "visualizer",
    "plugin",
    "ai",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "1.17.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1"
  }
}
