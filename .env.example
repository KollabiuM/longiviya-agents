# Claude Office Visualizer - Environment Configuration
# Copy this file to .env and configure for your system

# =============================================================================
# Required for Docker Deployment
# =============================================================================

# Path to your .claude directory on the host system
# This is required for Docker to translate paths correctly
#
# macOS example:
# CLAUDE_PATH_HOST=/Users/yourusername/.claude
#
# Linux example:
# CLAUDE_PATH_HOST=/home/yourusername/.claude
CLAUDE_PATH_HOST=

# =============================================================================
# Optional: AI Summaries
# =============================================================================
# Summaries (agent names, task blurbs, response/boss bubbles) are generated by
# a pluggable backend selected via SUMMARY_BACKEND. CLAUDE_CODE_OAUTH_TOKEN is
# no longer required — auth is handled by the chosen backend.

# Backend: claude-cli (default) | openai | disabled
# SUMMARY_BACKEND=claude-cli

# Master switch. When false, local fallback text is used regardless of backend.
# SUMMARY_ENABLED=true

# Shared cap on in-flight summary calls (each blocks its event handler briefly).
# SUMMARY_CONCURRENCY=4

# --- claude-cli backend (auth via your logged-in Claude subscription) ---
# Path to the claude binary (must be on PATH or absolute). Used as:
#   claude -p --bare --no-session-persistence --model <SUMMARY_MODEL> ...
# SUMMARY_CLI_PATH=claude
# SUMMARY_CLI_TIMEOUT=15.0
# Model passed via --model:
# SUMMARY_MODEL=claude-haiku-4-5-20251001

# --- openai-compatible backend (OpenAI, OpenRouter, Ollama, LM Studio, vLLM) ---
# SUMMARY_BACKEND=openai
# SUMMARY_OPENAI_BASE_URL=https://api.openai.com/v1
# SUMMARY_OPENAI_API_KEY=sk-...            # leave empty for keyless local servers
# SUMMARY_OPENAI_MODEL=gpt-4o-mini
# SUMMARY_OPENAI_TIMEOUT=15.0

# =============================================================================
# Optional: Database
# =============================================================================

# Database URL (default: SQLite in container volume)
# DATABASE_URL=sqlite+aiosqlite:///app/data/visualizer.db

# =============================================================================
# Optional: Git Polling
# =============================================================================

# How often to poll git status (seconds)
# GIT_POLL_INTERVAL=5
