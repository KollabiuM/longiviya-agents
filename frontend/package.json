{
  "name": "frontend",
  "version": "0.23.0",
  "//": [
    "Dependency policy (ARC-027, 2026-07): runtime `dependencies` are exact-pinned",
    "for reproducible builds; `devDependencies` use caret ranges so build tools",
    "float within minor.",
    "`overrides`: all @typescript-eslint/* sub-packages pinned to 8.56.1 to match",
    "the typescript-eslint umbrella. eslint-config-next 16.2.9 permits ^8.46.0 of",
    "the umbrella; without these pins, transitive resolution can mix 8.4x-era",
    "sub-packages with the 8.56.1 umbrella and crash lint rules. Re-evaluate on",
    "the next eslint-config-next upgrade."
  ],
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@pixi/react": "8.0.5",
    "@xstate/react": "6.1.0",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "lucide-react": "1.20.0",
    "next": "16.2.9",
    "pixi.js": "8.19.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-zoom-pan-pinch": "4.0.3",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "3.6.0",
    "xstate": "5.32.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.5",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "json-schema-to-typescript": "^15.0.4",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "typescript-eslint": "8.56.1",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@typescript-eslint/utils": "8.56.1",
    "@typescript-eslint/types": "8.56.1",
    "@typescript-eslint/typescript-estree": "8.56.1",
    "@typescript-eslint/scope-manager": "8.56.1",
    "@typescript-eslint/visitor-keys": "8.56.1",
    "@typescript-eslint/type-utils": "8.56.1",
    "@typescript-eslint/project-service": "8.56.1",
    "@typescript-eslint/tsconfig-utils": "8.56.1"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
